{
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.5.1",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "wrangler": "^4.111.0"
  },
  "name": "finance-control-api",
  "version": "1.0.0",
  "description": "Um app web simples e direto para controle de finanças pessoais. A ideia é centralizar entradas e saídas de dinheiro, organizar gastos e fornecer uma visão clara de como o dinheiro está sendo utilizado ao longo do tempo.",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler dev",
    "db:generate": "drizzle-kit generate --config=database/drizzle.config.ts",
    "db:migrate": "wrangler d1 migrations apply finance --local",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
